# =============================================================================
# Host4Me Backend Environment Variables
# Copy to .env and fill in your values
# =============================================================================

# --- Ollama ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_PRIMARY=gemma4:e4b
OLLAMA_MODEL_FAST=gemma4:e2b

# --- PostgreSQL ---
DATABASE_URL=postgresql://host4me:changeme@localhost:5432/host4me
POSTGRES_USER=host4me
POSTGRES_PASSWORD=changeme
POSTGRES_DB=host4me

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Credential Vault ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VAULT_ENCRYPTION_KEY=your-64-char-hex-key-here

# --- Telegram ---
# Pre-created bot tokens (comma-separated pool)
TELEGRAM_BOT_TOKENS=token1,token2,token3
# Webhook base URL (your VPS domain)
TELEGRAM_WEBHOOK_BASE=https://yourdomain.com/api/telegram

# --- ADK Agent Runner ---
ADK_RUNNER_URL=http://localhost:3200
# Internal URL for agent tools to call back to the Express server
BACKEND_INTERNAL_URL=http://localhost:3000
# Directory for PM data (properties, house rules, style, onboarding state)
HOST4ME_DATA_DIR=/opt/host4me/data

# --- Server ---
PORT=3000
NODE_ENV=production

# --- Browser Agents (Python) ---
BROWSER_AGENT_URL=http://localhost:8100
BROWSER_POLL_INTERVAL_MS=180000

# --- Mini App ---
MINI_APP_URL=https://yourdomain.com/onboarding
