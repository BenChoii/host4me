{
  "framework": "vite",
  "buildCommand": "vite build && mv dist/index.html dist/app.html",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/scripts/:file",
      "headers": [
        { "key": "Content-Type", "value": "text/javascript; charset=utf-8" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/", "destination": "/Host4Me.html" },
    { "source": "/scripts/:file", "destination": "/scripts/:file" },
    { "source": "/:path*", "destination": "/app.html" }
  ]
}
